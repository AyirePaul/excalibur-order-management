# Local development environment template. Copy to .env and fill in.
# Never commit a populated .env. Cloud envs read from AWS Secrets Manager.

# --- Database (local docker-compose) ---
POSTGRES_USER=orders
POSTGRES_PASSWORD=orders
POSTGRES_DB=orders
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Backend (FastAPI) ---
APP_ENV=local
APP_LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://orders:orders@db:5432/orders
CORS_ORIGINS=http://localhost:5173
ENABLE_DOCS=true

# --- AWS (local only — production reads via task role) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Cognito (set after `terragrunt apply` of cognito module in dev) ---
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_REGION=us-east-1
COGNITO_DOMAIN=

# --- Reports ---
REPORTS_BUCKET=
REPORT_RUNNER_TASK_DEFINITION=

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:8000
VITE_COGNITO_AUTHORITY=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/auth/callback

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=orders-api