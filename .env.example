# Local development environment template. Copy to .env and fill in.
# Never commit a populated .env.

# --- Database (local docker-compose) ---
POSTGRES_USER=orders
POSTGRES_PASSWORD=orders
POSTGRES_DB=orders
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Backend (FastAPI) ---
APP_ENV=local
APP_LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://orders:orders@db:5432/orders
CORS_ORIGINS=http://localhost:5173
ENABLE_DOCS=true

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:8000
