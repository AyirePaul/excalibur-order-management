<?xml version="1.0" encoding="UTF-8"?>
<!-- JasperReports: Orders by Month report -->
<!-- Parameters: P_DATE_FROM (Date), P_DATE_TO (Date), P_AMOUNT_MIN (BigDecimal) -->
<jasperReport
    xmlns="http://jasperreports.sourceforge.net/jasperreports"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
        http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
    name="orders_by_month"
    pageWidth="595"
    pageHeight="842"
    columnWidth="535"
    leftMargin="30"
    rightMargin="30"
    topMargin="30"
    bottomMargin="30"
    uuid="12345678-0000-0000-0000-000000000001">

    <property name="com.jaspersoft.studio.data.sql.tables" value=""/>

    <parameter name="P_DATE_FROM" class="java.util.Date">
        <defaultValueExpression><![CDATA[new java.util.Date()]]></defaultValueExpression>
    </parameter>
    <parameter name="P_DATE_TO" class="java.util.Date">
        <defaultValueExpression><![CDATA[new java.util.Date()]]></defaultValueExpression>
    </parameter>
    <parameter name="P_AMOUNT_MIN" class="java.math.BigDecimal">
        <defaultValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></defaultValueExpression>
    </parameter>

    <queryString language="SQL">
        <![CDATA[
        SELECT
            order_id,
            order_date,
            order_amount,
            order_description,
            TO_CHAR(order_date, 'YYYY-MM') AS order_month
        FROM order_combined
        WHERE order_date BETWEEN $P{P_DATE_FROM} AND $P{P_DATE_TO}
          AND order_amount >= $P{P_AMOUNT_MIN}
        ORDER BY order_date ASC, order_amount DESC
        ]]>
    </queryString>

    <field name="order_id"          class="java.lang.String"/>
    <field name="order_date"        class="java.util.Date"/>
    <field name="order_amount"      class="java.math.BigDecimal"/>
    <field name="order_description" class="java.lang.String"/>
    <field name="order_month"       class="java.lang.String"/>

    <variable name="TOTAL_AMOUNT" class="java.math.BigDecimal" calculation="Sum">
        <variableExpression><![CDATA[$F{order_amount}]]></variableExpression>
    </variable>

    <!-- ── Title Band ──────────────────────────────────────────────── -->
    <title>
        <band height="60">
            <staticText>
                <reportElement x="0" y="0" width="535" height="30"/>
                <textElement textAlignment="Center">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[Orders Report by Month]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="30" width="535" height="20"/>
                <textElement textAlignment="Center">
                    <font size="9" isItalic="true"/>
                </textElement>
                <textFieldExpression><![CDATA[
                    "Period: " + new java.text.SimpleDateFormat("yyyy-MM-dd").format($P{P_DATE_FROM})
                    + " to " + new java.text.SimpleDateFormat("yyyy-MM-dd").format($P{P_DATE_TO})
                    + "  |  Min amount: $" + $P{P_AMOUNT_MIN}.toPlainString()
                ]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <!-- ── Column Header ───────────────────────────────────────────── -->
    <columnHeader>
        <band height="24">
            <rectangle>
                <reportElement x="0" y="0" width="535" height="24" backcolor="#1E3A8A"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="5"   y="4" width="90"  height="16" forecolor="#FFFFFF"/>
                <textElement><font isBold="true" size="8"/></textElement>
                <text><![CDATA[Date]]></text>
            </staticText>
            <staticText>
                <reportElement x="100" y="4" width="90"  height="16" forecolor="#FFFFFF"/>
                <textElement><font isBold="true" size="8"/></textElement>
                <text><![CDATA[Amount]]></text>
            </staticText>
            <staticText>
                <reportElement x="195" y="4" width="335" height="16" forecolor="#FFFFFF"/>
                <textElement><font isBold="true" size="8"/></textElement>
                <text><![CDATA[Description]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- ── Detail ──────────────────────────────────────────────────── -->
    <detail>
        <band height="20" splitType="Stretch">
            <textField>
                <reportElement x="5"   y="2" width="90"  height="16"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[new java.text.SimpleDateFormat("yyyy-MM-dd").format($F{order_date})]]></textFieldExpression>
            </textField>
            <textField pattern="$#,##0.00">
                <reportElement x="100" y="2" width="90"  height="16"/>
                <textElement textAlignment="Right"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{order_amount}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="195" y="2" width="335" height="16"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{order_description}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- ── Summary ─────────────────────────────────────────────────── -->
    <summary>
        <band height="30">
            <line>
                <reportElement x="0" y="0" width="535" height="1"/>
            </line>
            <staticText>
                <reportElement x="5" y="5" width="180" height="20"/>
                <textElement><font isBold="true" size="9"/></textElement>
                <text><![CDATA[Total]]></text>
            </staticText>
            <textField pattern="$#,##0.00">
                <reportElement x="100" y="5" width="90" height="20"/>
                <textElement textAlignment="Right"><font isBold="true" size="9"/></textElement>
                <textFieldExpression><![CDATA[$V{TOTAL_AMOUNT}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
