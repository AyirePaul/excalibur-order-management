{
  "widgets": [
    {
      "type": "metric",
      "x": 0, "y": 0, "width": 8, "height": 6,
      "properties": {
        "title": "Request Rate (req/min)",
        "metrics": [
          ["AWS/ApplicationELB", "RequestCount", "LoadBalancer", "${LoadBalancer}", { "stat": "Sum", "period": 60 }]
        ],
        "view": "timeSeries",
        "region": "us-east-1"
      }
    },
    {
      "type": "metric",
      "x": 8, "y": 0, "width": 8, "height": 6,
      "properties": {
        "title": "p95 Latency (ms)",
        "metrics": [
          ["AWS/ApplicationELB", "TargetResponseTime", "LoadBalancer", "${LoadBalancer}", { "stat": "p95", "period": 60 }]
        ],
        "view": "timeSeries",
        "region": "us-east-1"
      }
    },
    {
      "type": "metric",
      "x": 16, "y": 0, "width": 8, "height": 6,
      "properties": {
        "title": "5xx Error Rate (%)",
        "metrics": [
          [{ "expression": "m2/m1*100", "label": "5xx Rate %", "id": "e1" }],
          ["AWS/ApplicationELB", "RequestCount", "LoadBalancer", "${LoadBalancer}", { "id": "m1", "stat": "Sum", "period": 60, "visible": false }],
          ["AWS/ApplicationELB", "HTTPCode_Target_5XX_Count", "LoadBalancer", "${LoadBalancer}", { "id": "m2", "stat": "Sum", "period": 60, "visible": false }]
        ],
        "view": "timeSeries",
        "region": "us-east-1"
      }
    },
    {
      "type": "metric",
      "x": 0, "y": 6, "width": 8, "height": 6,
      "properties": {
        "title": "ECS CPU Utilization (%)",
        "metrics": [
          ["AWS/ECS", "CPUUtilization", "ClusterName", "${ClusterName}", "ServiceName", "${ServiceName}", { "stat": "Average", "period": 60 }]
        ],
        "view": "timeSeries",
        "region": "us-east-1"
      }
    },
    {
      "type": "metric",
      "x": 8, "y": 6, "width": 8, "height": 6,
      "properties": {
        "title": "ECS Memory Utilization (%)",
        "metrics": [
          ["AWS/ECS", "MemoryUtilization", "ClusterName", "${ClusterName}", "ServiceName", "${ServiceName}", { "stat": "Average", "period": 60 }]
        ],
        "view": "timeSeries",
        "region": "us-east-1"
      }
    },
    {
      "type": "metric",
      "x": 16, "y": 6, "width": 8, "height": 6,
      "properties": {
        "title": "Unhealthy Host Count",
        "metrics": [
          ["AWS/ApplicationELB", "UnHealthyHostCount", "LoadBalancer", "${LoadBalancer}", { "stat": "Average", "period": 60 }]
        ],
        "view": "timeSeries",
        "region": "us-east-1"
      }
    }
  ]
}
